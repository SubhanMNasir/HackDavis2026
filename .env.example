# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional Clerk URL overrides — defaults usually fine
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# MongoDB (Atlas M10)
MONGODB_URI=

# Google Generative AI (Gemini 2.5 Flash)
GOOGLE_API_KEY=

# App URL — set per-environment (Vercel injects automatically in preview/prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
